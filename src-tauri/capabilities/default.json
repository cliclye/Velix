{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "velix-*"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "opener:default",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:scope-home-recursive",
    "http:default",
    "http:allow-fetch"
  ]
}